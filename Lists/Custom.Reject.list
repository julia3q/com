# === 阻斷bilibili stun*.chat ===
DOMAIN-WILDCARD,stun*.chat.bilibili.com,REJECT,extended-matching

# === 🍎 蘋果特殊請求 (Apple Edge/Continuity) ===
DOMAIN-SUFFIX,safebrowsing.apple
DOMAIN-KEYWORD,safebrowsing
DOMAIN-KEYWORD,app-site.association
DOMAIN,tether.edge.apple

# === 🚫 錯誤追蹤與廣告 (Trackers & Ads) ===
DOMAIN-SUFFIX,sentry.io
DOMAIN-SUFFIX,ads.superad.cc

# === 🔞 成人過濾 (NSFW) ===
DOMAIN-SUFFIX,avple.tv
DOMAIN-SUFFIX,javrate.com
DOMAIN-SUFFIX,missav.ws
DOMAIN-KEYWORD,jable
DOMAIN-KEYWORD,missav

